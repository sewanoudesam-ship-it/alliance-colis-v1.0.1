{
    "compilerOptions": {
        "target": "ES2023",
            "useDefineForClassFields": true,
                "lib": ["ES2023", "DOM", "DOM.Iterable"],
                    "module": "ESNext",
                        "skipLibCheck": true,

                            "moduleResolution": "bundler",
                                "resolveJsonModule": true,
                                    "isolatedModules": true,
                                        "noEmit": true,

                                            "jsx": "react-jsx",
                                                "strict": true,
                                                    "noImplicitAny": false,
                                                        "types": ["vite/client"]
                                                          },
                                                            "include": ["src"]
                                                            }