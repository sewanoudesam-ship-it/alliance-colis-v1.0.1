# Supabase — Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Carte (optionnel — Leaflet/OpenStreetMap est utilisé par défaut, gratuit, sans clé).
# Laissez vide pour rester sur OpenStreetMap.
VITE_GOOGLE_MAPS_API_KEY=

# ------------------------------------------------------------------------------
# Paiement (SenePay) — AUCUNE clé de paiement ici.
# Les clés SenePay (X-Api-Key / X-Api-Secret / webhook secret) vivent uniquement
# dans les secrets des Edge Functions Supabase : voir supabase/functions/.env
# et supabase/functions/README.md. Ne JAMAIS ajouter VITE_SENEPAY_* ici : tout
# ce qui commence par VITE_ finit dans le bundle JavaScript public.
# ------------------------------------------------------------------------------
